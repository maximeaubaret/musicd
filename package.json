{
  "name": "jellyfin-music-daemon",
  "version": "0.1.0",
  "description": "A daemon that plays music from Jellyfin",
  "type": "module",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "bun --watch packages/server/src/index.ts",
    "cli": "bun packages/cli/src/index.ts",
    "build": "bun run --filter '*' build",
    "build:shared": "bun run --filter @musicd/shared build",
    "build:client": "bun run --filter @musicd/client build",
    "build:server": "bun run --filter @musicd/server build",
    "build:cli": "bun run --filter @musicd/cli build",
    "format": "prettier --write .",
    "lint": "bun run --filter '*' lint",
    "clean": "rm -rf packages/*/dist"
  },
  "devDependencies": {
    "@types/bun": "^1.3.9",
    "@types/node": "^20.11.0",
    "eslint": "^8.56.0",
    "prettier": "^3.2.4",
    "typescript": "^5.3.3"
  }
}
