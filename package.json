{
  "name": "jellyfin-music-daemon",
  "version": "1.0.0",
  "description": "A daemon that plays music from Jellyfin",
  "type": "module",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "bun --watch packages/server/src/index.ts",
    "server": "bun packages/server/src/index.ts",
    "cli": "bun packages/cli/src/index.ts",
    "build:cli": "bun run --filter @musicd/cli build:cli",
    "format": "prettier --write .",
    "lint": "bun run --filter '*' lint",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf packages/*/dist bin/",
    "test": "bun test"
  },
  "devDependencies": {
    "@types/bun": "^1.3.9",
    "@types/node": "^20.11.0",
    "@typescript-eslint/eslint-plugin": "^8.56.0",
    "@typescript-eslint/parser": "^8.56.0",
    "eslint": "^8.56.0",
    "prettier": "^3.2.4",
    "typescript": "^5.3.3"
  }
}
